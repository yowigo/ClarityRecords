@page "/Error"
@using System.Diagnostics

<PageTitle>出错了 — 澄明录</PageTitle>

<h1 class="text-danger">出错了。</h1>
<h2 class="text-danger">处理请求时发生了错误。</h2>

@if (ShowRequestId)
{
    <p>
        <strong>请求 ID：</strong> <code>@RequestId</code>
    </p>
}

<h3>开发模式说明</h3>
<p>
    切换到 <strong>Development</strong> 环境可以查看更详细的错误信息。
</p>
<p>
    <strong>请勿在生产环境中启用 Development 模式。</strong>
    这可能会将敏感的异常信息暴露给用户。
    本地调试时，将 <strong>ASPNETCORE_ENVIRONMENT</strong> 环境变量设置为 <strong>Development</strong> 并重启应用即可。
</p>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}

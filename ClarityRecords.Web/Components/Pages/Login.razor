@page "/login"
@layout EmptyLayout

<PageTitle>进入 · 澄明录</PageTitle>

<div class="login-page">
    <div class="login-brand">
        <a href="/" class="login-site-title">澄明录</a>
        <div class="login-subtitle">// 管理入口</div>
    </div>

    <div class="login-card">
        @if (Error == "1")
        {
            <div class="login-error">用户名或密码错误</div>
        }

        <form method="post" action="/account/login">
            <AntiforgeryToken />
            <div class="login-field">
                <label class="login-label" for="username">用户名</label>
                <input id="username" name="username" type="text"
                       class="login-input" autocomplete="username" required autofocus />
            </div>
            <div class="login-field">
                <label class="login-label" for="password">密码</label>
                <div class="login-input-wrap">
                    <input id="password" name="password" type="password"
                           class="login-input" autocomplete="current-password" required />
                    <button type="button" class="login-eye-btn" onclick="togglePasswordVisibility()" aria-label="显示或隐藏密码">
                        <svg id="eye-show" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                        <svg id="eye-hide" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
                            <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/>
                            <line x1="1" y1="1" x2="23" y2="23"/>
                        </svg>
                    </button>
                </div>
            </div>
            <div class="login-remember">
                <input id="remember" name="rememberMe" type="checkbox" value="true"
                       class="login-checkbox" checked />
                <label for="remember" class="login-remember-label">记住我（30天）</label>
            </div>
            <button type="submit" class="login-btn">→ 进入</button>
        </form>
    </div>

    <div class="login-back">
        <a href="/">← 返回首页</a>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    private string? Error { get; set; }
}

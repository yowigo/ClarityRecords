@page "/change-password"
@layout EmptyLayout
@inject NavigationManager Nav

<PageTitle>修改密码 · 澄明录</PageTitle>

<div class="login-page">
    <div class="login-brand">
        <a href="/" class="login-site-title">澄明录</a>
        <div class="login-subtitle">// 首次登录，请修改密码</div>
    </div>

    <div class="login-card">
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="login-error">@_error</div>
        }

        <form method="post" action="/account/change-password">
            <AntiforgeryToken />
            <input type="hidden" name="userId" value="@UserId" />
            <div class="login-field">
                <label class="login-label" for="newPassword">新密码</label>
                <input id="newPassword" name="newPassword" type="password"
                       class="login-input" autocomplete="new-password" required autofocus />
            </div>
            <div class="login-field">
                <label class="login-label" for="confirmPassword">确认密码</label>
                <input id="confirmPassword" name="confirmPassword" type="password"
                       class="login-input" autocomplete="new-password" required />
            </div>
            <button type="submit" class="login-btn">→ 确认修改</button>
        </form>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "userId")]
    private string? UserId { get; set; }

    [SupplyParameterFromQuery(Name = "error")]
    private string? ErrorCode { get; set; }

    private string? _error;

    protected override void OnInitialized()
    {
        if (string.IsNullOrEmpty(UserId))
            Nav.NavigateTo("/login", forceLoad: true);

        _error = ErrorCode switch
        {
            "mismatch" => "两次输入的密码不一致",
            "weak" => "密码强度不足（至少 8 位）",
            "failed" => "密码修改失败，请重试",
            _ => null
        };
    }
}

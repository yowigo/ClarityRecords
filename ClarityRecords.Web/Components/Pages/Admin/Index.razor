@page "/admin"
@layout AdminLayout
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using ClarityRecords.Infrastructure.Data
@using ClarityRecords.Infrastructure.Identity
@inject IDbContextFactory<AppDbContext> DbFactory
@inject UserManager<ApplicationUser> UserManager

<PageTitle>仪表盘 · 澄明录</PageTitle>

<h1 class="admin-page-title">仪表盘</h1>

<div class="admin-stats">
    <div class="stat-card">
        <div class="stat-card-value">@_totalArticles</div>
        <div class="stat-card-label">文章总数</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-value">@_publishedArticles</div>
        <div class="stat-card-label">已发布</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-value">@_draftArticles</div>
        <div class="stat-card-label">草稿</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-value">@_totalUsers</div>
        <div class="stat-card-label">用户数</div>
    </div>
    <div class="stat-card">
        <div class="stat-card-value">@_knowledgeLinks</div>
        <div class="stat-card-label">知识链接</div>
    </div>
</div>

<div style="display:flex; gap:12px; flex-wrap:wrap;">
    <a href="/admin/articles/new" class="btn-primary">+ 新建文章</a>
    <a href="/admin/users" class="btn-secondary">邀请用户</a>
    <a href="/admin/knowledge-links" class="btn-secondary">管理知识链接</a>
</div>

@code {
    private int _totalArticles;
    private int _publishedArticles;
    private int _draftArticles;
    private int _totalUsers;
    private int _knowledgeLinks;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var now = DateTimeOffset.UtcNow;

        _totalArticles = await db.Articles.CountAsync();
        _publishedArticles = await db.Articles.CountAsync(a => a.PublishedAt != null && a.PublishedAt <= now);
        _draftArticles = _totalArticles - _publishedArticles;
        _knowledgeLinks = await db.ArticleManualLinks.CountAsync();
        _totalUsers = await UserManager.Users.CountAsync();
    }
}
